# Copy this file to .env.local for local development, or set VITE_API_URL
# as an environment variable in your hosting dashboard (e.g. Vercel) when
# deploying.
#
# Leave this unset for local development — requests fall through to "/api",
# which the Vite dev server proxies to http://localhost:5000 automatically
# (see vite.config.js). You only need to set this once you deploy, pointing
# it at your live backend's full URL:
#
# VITE_API_URL=https://your-backend.vercel.app/api